// ============================================================================
// 高级规则示例（advanced.json5）
// ============================================================================
// 展示所有高级匹配方式和回复类型：
//
// 【匹配条件 when】
//   1. 字符串        → "hello"                 精确匹配
//   2. 正则字符串    → "/pattern/i"            正则匹配（支持 i/m/s/u 标志）
//   3. 对象          → { message, model, system, format } 多字段复合匹配
//
// 【回复内容 reply】
//   1. 字符串        → "text reply"            普通文本回复
//   2. 对象          → { text, reasoning, tools } 结构化回复
//     - text:        主文本内容
//     - reasoning:   思考过程文本
//     - tools:       工具调用列表 [{ name, args }]
//
// 【模板引用 templates + $name】
//   在 templates 中定义回复，在 reply 中使用 "$templateName" 引用
//
// 【fallback】
//   全局默认回复。当所有规则都不匹配时返回此内容。
// ============================================================================

{
  // -------------------------------------------------------------------------
  // 模板：可复用的回复
  // -------------------------------------------------------------------------
  templates: {
    // 标准的 "无法回答" 回复
    cant_answer: {
      text: "抱歉，我无法回答这个问题。请换一种问法。",
    },

    // 工具调用：获取天气
    weather_tool: {
      text: "正在为您查询天气...",
      tools: [
        {
          name: "get_weather",
          args: { location: "Beijing", unit: "celsius" },
        },
      ],
    },

    // 工具调用：数据库查询
    db_query: {
      text: "正在执行数据库查询...",
      tools: [
        {
          name: "run_sql",
          args: { query: "SELECT * FROM users LIMIT 10" },
        },
      ],
    },
  },

  // -------------------------------------------------------------------------
  // 全局 fallback（所有规则都不匹配时的默认回复）
  // -------------------------------------------------------------------------
  fallback: "这是 advanced.json5 中定义的 fallback：没有匹配到任何规则，请尝试其他消息。",

  // -------------------------------------------------------------------------
  // 规则列表
  // -------------------------------------------------------------------------
  rules: [
    // --- 正则匹配示例 ---------------------------------------------------

    // 1. 正则：以 "tell me about" 开头，不区分大小写
    {
      when: "/^tell me about .*/i",
      reply: "这是一个正则匹配的回复。你可以使用 /pattern/flags 格式定义正则表达式。",
    },

    // 2. 正则：包含数字
    {
      when: "/\\d+/",
      reply: "你的消息中包含数字，触发了正则匹配规则。",
    },

    // 3. 正则：匹配邮箱格式
    {
      when: "/^\\w+@\\w+\\.\\w+$/",
      reply: "我识别到了一个邮箱地址格式的字符串。",
    },

    // --- 对象匹配示例 ---------------------------------------------------

    // 4. 对象匹配：只按 message 字段
    {
      when: {
        message: "test_object_match",
      },
      reply: "通过对象形式的匹配条件命中了此规则。",
    },

    // 5. 对象匹配：按消息内容 + 模型名
    {
      when: {
        message: "check_model",
        model: "gpt-4",
      },
      reply: "识别到消息为 check_model，且请求来自 gpt-4 模型。",
    },

    // 6. 对象匹配：仅 OpenAI 格式（只对 /v1/chat/completions 路由生效）
    {
      when: {
        message: "openai_only",
        format: "openai",
      },
      reply: "这条规则只对 OpenAI 格式的请求生效。",
    },

    // 7. 对象匹配：仅 Anthropic 格式
    {
      when: {
        message: "anthropic_only",
        format: "anthropic",
      },
      reply: "这条规则只对 Anthropic 格式的请求生效。",
    },

    // 8. 对象匹配：检查 system prompt 内容
    {
      when: {
        system: "/you are a helpful assistant/i",
      },
      reply: "识别到 system prompt 中包含 'you are a helpful assistant'。",
    },

    // --- 结构化回复示例 -------------------------------------------------

    // 9. 带 reasoning（思考过程）的回复
    {
      when: "带思考",
      reply: {
        reasoning: "我正在理解用户的问题，分析意图后给出合适的回答。",
        text: "这是最终的回复内容。前面的 reasoning 字段可用于调试或日志。",
      },
    },

    // 10. 工具调用回复（使用模板 $weather_tool）
    {
      when: "weather",
      reply: "$weather_tool",
    },
    {
      when: "天气",
      reply: "$weather_tool",
    },

    // 11. 另一个工具调用（数据库查询）
    {
      when: "run_sql",
      reply: "$db_query",
    },

    // 12. 多工具调用
    {
      when: "多工具",
      reply: {
        text: "已触发多个工具调用。",
        tools: [
          {
            name: "tool_1",
            args: { param_1: "value_1" },
          },
          {
            name: "tool_2",
            args: { param_2: "value_2" },
          },
          {
            name: "tool_3",
            args: {},
          },
        ],
      },
    },

    // --- 复杂匹配 --------------------------------------------------------

    // 13. 正则 + 对象的混合
    {
      when: {
        message: "/^query_.*$/i",
        model: "/gpt-.*/",
      },
      reply: "识别到消息以 query_ 开头，且请求来自 gpt-* 系列模型。",
    },

    // 14. 模板引用（复用 cant_answer 模板）
    {
      when: "i dont know",
      reply: "$cant_answer",
    },
  ],
}
