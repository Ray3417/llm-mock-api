// ============================================================================
// 序列回复示例（sequence.json5）
// ============================================================================
// 展示 "replies" 字段：同一个匹配词触发多条不同的回复，依次推进。
//
// 每条序列回复包含：
//   replies: [ reply1, reply2, ... ]
//     每一项可以是：
//     a) 字符串（当作文本回复）
//     b) 对象 { reply, latency?, chunkSize? }
//        - reply:     回复内容（字符串或 ReplyObject）
//        - latency:   此条回复的延迟（毫秒，覆盖全局 default_latency）
//        - chunkSize: 此条回复的分块大小（覆盖全局 default_chunk_size）
//
// 匹配到 when 时，第一次请求返回 replies[0]，第二次返回 replies[1]，
// 依次类推。所有回复消费完后，最后一条回复会被重复返回（不再触发新规则）。
//
// 关于模板引用：
//   同一文件顶部定义的 templates 可以通过 "$templateName" 在此文件内引用。
//   注意：templates 只在当前 JSON5 文件内可见，不能跨文件引用。
// ============================================================================

{
  // 本文件内可用的模板（sequence 内可通过 $weather_tool 等方式引用）
  templates: {
    seq_weather: {
      text: "（序列）已调用天气工具，等待结果。",
      tools: [
        {
          name: "get_weather",
          args: { location: "Shanghai", unit: "celsius" },
        },
      ],
    },
  },

  rules: [
    // --- 基础序列：依次返回不同消息 -----------------------------------

    {
      when: "对话推进",
      replies: [
        "这是第一次回复。",
        "这是第二次回复。",
        "这是第三次，也是最后一次回复。",
      ],
    },

    // --- 带延迟的序列：每条回复有不同延迟 ------------------------------

    {
      when: "慢速对话",
      replies: [
        { reply: "快速回复，立即返回。", latency: 0, chunkSize: 0 },
        { reply: "中速回复，200ms 延迟并分块。", latency: 200, chunkSize: 20 },
        { reply: "慢速回复，500ms 延迟。", latency: 500, chunkSize: 30 },
      ],
    },

    // --- 结构化回复的序列 ----------------------------------------------

    {
      when: "结构化对话",
      replies: [
        {
          text: "第一步：分析问题。",
          reasoning: "用户需要完成一个多步骤的流程。",
        },
        {
          text: "第二步：准备数据。",
          tools: [
            {
              name: "fetch_data",
              args: { source: "db" },
            },
          ],
        },
        { text: "第三步：输出结果。" },
      ],
    },

    // --- 模拟对话流程：一问一答推进 -------------------------------------

    {
      when: "登录",
      replies: [
        "请输入用户名。",
        "请输入密码。",
        "登录成功！欢迎回来。",
      ],
    },

    // --- 模板引用的序列 -------------------------------------------------

    {
      when: "模板序列",
      replies: [
        "$seq_weather", // 引用本文件中定义的 seq_weather 模板
        "数据已就绪，请检查。",
        "所有步骤完成。",
      ],
    },
  ],
}
